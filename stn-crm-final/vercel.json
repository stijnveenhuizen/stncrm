{
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "functions": {
    "api/monitor/run-checks.js": { "maxDuration": 60 },
    "api/monitor/pagespeed.js": { "maxDuration": 60 },
    "api/monitor/uptime.js": { "maxDuration": 30 },
    "api/admin.js": { "maxDuration": 30 },
    "api/outreach.js": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/monitor/run-checks", "schedule": "0 6 * * *" },
    { "path": "/api/outreach", "schedule": "0 8 * * *" }
  ]
}
